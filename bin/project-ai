#!/usr/bin/env python3
"""project-ai CLI --- 产品迭代管理命令行工具。

确定性操作交给代码，不确定性交给大模型。

用法：
  python bin/project-ai init
  python bin/project-ai status --json
  python bin/project-ai validate --json

路径说明：
  本脚本会自动查找同项目下的 src/project_ai/ 目录。
  无论你从哪个目录运行本脚本，它都会正确定位到 src/。
  如果你把 bin/project-ai 和 src/project_ai/ 一起复制到你的项目根目录，
  运行 python bin/project-ai 即可正常工作。
"""

import sys
import os

# ---- 路径查找 ----
# 策略 1：从脚本所在位置推算项目根目录
_SCRIPT_FILE = os.path.abspath(__file__)
_TOOLKIT_ROOT = os.path.dirname(os.path.dirname(_SCRIPT_FILE))
_SRC = os.path.join(_TOOLKIT_ROOT, "src")

# 策略 2：如果策略 1 的路径不存在（比如脚本被单独移动了），
#         从当前工作目录往上找 src/project_ai/
if not os.path.isdir(os.path.join(_SRC, "project_ai")):
    _cwd = os.getcwd()
    _SRC = os.path.join(_cwd, "src")
    # 如果当前目录也没有，尝试父目录
    if not os.path.isdir(os.path.join(_SRC, "project_ai")):
        _parent = os.path.dirname(_cwd)
        _SRC = os.path.join(_parent, "src")

if _SRC not in sys.path:
    sys.path.insert(0, _SRC)

try:
    from project_ai.cli import main
except ImportError:
    print("错误：找不到 project_ai 模块。", file=sys.stderr)
    print(f"  已尝试路径: {_SRC}", file=sys.stderr)
    print("  请确保 bin/project-ai 和 src/project_ai/ 在同一个项目根目录下。", file=sys.stderr)
    sys.exit(1)

if __name__ == "__main__":
    sys.exit(main())
